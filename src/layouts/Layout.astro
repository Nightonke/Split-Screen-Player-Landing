---
/** biome-ignore-all lint/correctness/noUnusedImports: React components are hydrated client-side with icons */
/** biome-ignore-all lint/correctness/noUnusedVariables: Props and config are passed to nested components */

import { siteConfig } from "@config/site";
import Footer from "@/sections/Footer";
import type { LayoutWithAppDataProps } from "@/types/layout";
import BackToTop from "@/ui/BackToTop";
import FloatingNavbar from "@/ui/FloatingNavbar";
import { landingContent } from "@/i18n/content";
import { defaultLocale, getLanguageLinks, localizedPath } from "@/i18n/locales";

interface Props extends LayoutWithAppDataProps {}

const {
	title,
	description,
	appData,
	lang = "en",
	keywords = siteConfig.keywords,
	alternates = getLanguageLinks(defaultLocale),
	homeHref = localizedPath(defaultLocale),
	privacyHref = localizedPath(defaultLocale, "privacy"),
	termsHref = localizedPath(defaultLocale, "terms"),
	labels = landingContent[defaultLocale].labels,
} = Astro.props;
const navData = appData || {
	name: siteConfig.name,
	shortName: siteConfig.name,
	logo: siteConfig.logo,
	description: siteConfig.description,
	storeLinks: siteConfig.storeLinks,
};
const navTitle = navData.shortName || navData.name;
const canonicalURL = Astro.site
	? new URL(Astro.url.pathname, Astro.site)
	: Astro.url;
const appleTouchIconURL = Astro.site
	? new URL(siteConfig.logo, Astro.site).href
	: siteConfig.logo;
const previewVideoURL = appData?.appPreview
	? Astro.site
		? new URL(appData.appPreview.videoSrc, Astro.site).href
		: appData.appPreview.videoSrc
	: undefined;
const previewPosterURL = appData?.appPreview
	? Astro.site
		? new URL(appData.appPreview.posterSrc, Astro.site).href
		: appData.appPreview.posterSrc
	: undefined;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="keywords" content={keywords.join(", ")} />
    
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    
    <link rel="canonical" href={canonicalURL} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hrefLang} href={Astro.site ? new URL(alternate.href, Astro.site).href : alternate.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={Astro.site ? new URL("/", Astro.site).href : "/"} />
    <meta property="og:title" content={title} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {description && <meta property="og:description" content={description} />}
    {previewPosterURL && <meta property="og:image" content={previewPosterURL} />}
    {previewVideoURL && <meta property="og:video" content={previewVideoURL} />}
    {previewVideoURL && <meta property="og:video:type" content="video/mp4" />}
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {previewPosterURL && <meta name="twitter:image" content={previewPosterURL} />}
    
    <link rel="icon" type="image/png" sizes="32x32" href={siteConfig.logo} />
    <link rel="icon" type="image/png" sizes="16x16" href={siteConfig.logo} />
    <link rel="icon" sizes="192x192" href={siteConfig.logo} />
    <link rel="icon" sizes="512x512" href={siteConfig.logo} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIconURL} />
    
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'system';
      document.documentElement.classList.remove('light', 'dark');
      
      if (theme === 'system') {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.classList.add(prefersDark ? 'dark' : 'light');
      } else {
        document.documentElement.classList.add(theme);
      }
      
      !localStorage.getItem('theme') && localStorage.setItem('theme', 'system');
    </script>
  </head>
  <body class="bg-gray-50 text-gray-900 dark:bg-black dark:text-white">
    <FloatingNavbar
      logo={navData.logo}
      title={navTitle}
      homeHref={homeHref}
      storeLinks={navData.storeLinks}
      socialLinks={siteConfig.socialLinks}
      labels={labels}
      languageLinks={alternates}
      client:load
    />
    <div class="mx-auto h-screen max-w-full px-2 lg:max-w-[1500px]">
      <main><slot /></main>
      <Footer
        name={navTitle}
        logo={navData.logo}
        description={navData.description}
        homeHref={homeHref}
        privacyHref={privacyHref}
        termsHref={termsHref}
        labels={labels}
        languageLinks={alternates}
        client:load
      />
    </div>
    <BackToTop client:load />
  </body>
</html>


<style is:global>
  html.theme-switching *,
  html.theme-switching {
    transition: none !important;
  }
  
  html.light { color-scheme: light; }
  html.dark { color-scheme: dark; }

  .screenshots-scrollbar::-webkit-scrollbar {
    height: 8px;
  }
  
  .screenshots-scrollbar::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.05);
    border-radius: 4px;
  }
  
  .dark .screenshots-scrollbar::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
  }
  
  .screenshots-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.15);
    border-radius: 4px;
  }
  
  .dark .screenshots-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
  }
  
  .screenshots-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 0, 0, 0.25);
  }
  
  .dark .screenshots-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.25);
  }
</style>
