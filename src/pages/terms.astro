---
/** biome-ignore-all lint/correctness/noUnusedImports: MarkdownContent component renders markdown content */
/** biome-ignore-all lint/correctness/noUnusedVariables: Content and config variables used in Layout props */

import { siteConfig } from "@config/site";
import Layout from "@layouts/Layout.astro";
import MarkdownContent from "@layouts/MarkdownContent.astro";

const termsContent = Object.values(
	import.meta.glob("./content/terms.md", { eager: true }),
)[0] as { rawContent(): string };
const markdownContent = termsContent.rawContent();
---

<Layout 
  title={`Terms of Service - ${siteConfig.name}`} 
  description="Read the terms for using Split Screen Player, including local media, web browsing, downloads, purchases, and third-party content."
>
  <MarkdownContent breadcrumbLabel="Terms of Service" content={markdownContent} />
</Layout>
