---
/** biome-ignore-all lint/correctness/noUnusedImports: MarkdownContent component renders markdown content */
/** biome-ignore-all lint/correctness/noUnusedVariables: Content and config variables used in Layout props */

import { siteConfig } from "@config/site";
import Layout from "@layouts/Layout.astro";
import MarkdownContent from "@layouts/MarkdownContent.astro";

const privacyContent = Object.values(
	import.meta.glob("./content/privacy.md", { eager: true }),
)[0] as { rawContent: () => string };
const markdownContent = privacyContent.rawContent();
---

<Layout 
  title={`Privacy Policy - ${siteConfig.name}`} 
  description="Learn how Split Screen Player handles local media, browsing activity, diagnostics, and privacy-related choices."
>
  <MarkdownContent breadcrumbLabel="Privacy Policy" content={markdownContent} />
</Layout>
