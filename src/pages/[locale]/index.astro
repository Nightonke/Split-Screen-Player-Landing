---
import LandingPage from "@layouts/LandingPage.astro";
import { landingContent } from "@/i18n/content";
import { defaultLocale, getLanguageLinks, locales, type Locale } from "@/i18n/locales";

export function getStaticPaths() {
	return locales
		.filter((locale) => locale !== defaultLocale)
		.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const content = landingContent[locale];
const languageLinks = getLanguageLinks(locale);
---

<LandingPage content={content} languageLinks={languageLinks} />
